{
  "name": "react-router-template",
  "private": true,
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev": "pnpm run docker:db && react-router dev",
    "dev:clean": "rm -rf node_modules/.vite && pnpm dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "react-router typegen && eslint .",
    "lint:fix": "react-router typegen && eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "kysely-codegen --out-file app/lib/db/database-types.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:connect": "docker exec -it $(docker compose ps -q postgres) psql -U ${POSTGRES_USER:-app} -d ${POSTGRES_DB:-app_dev}",
    "docker:db": "docker compose rm -sf postgres && docker compose up -d --remove-orphans postgres",
    "docker:down": "docker compose down --remove-orphans",
    "docker:ps": "docker compose ps",
    "docker:logs": "docker compose logs -f postgres",
    "docker:app": "docker compose up --build -d --remove-orphans",
    "docker:build": "docker build -t react-router-template .",
    "docker:up": "docker compose up --build -d --remove-orphans",
    "docker:migrate": "docker compose run --build --rm app pnpm db:migrate:deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@ai-sdk/react": "^3.0.210",
    "@mantine/core": "^9.3.2",
    "@mantine/form": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/modals": "^9.3.2",
    "@mantine/notifications": "^9.3.2",
    "@mantine/nprogress": "^9.3.2",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "ai": "^6.0.208",
    "better-auth": "^1.6.19",
    "isbot": "^5.1.43",
    "kysely": "^0.29.2",
    "lucide-react": "^1.21.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^8.0.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^8.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/node": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-mantine": "^4.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "kysely-codegen": "^0.20.0",
    "lint-staged": "^17.0.7",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
