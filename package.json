{
  "name": "react-router-template",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:connect": "docker exec -it $(docker compose ps -q postgres) psql -U ${POSTGRES_USER:-app} -d ${POSTGRES_DB:-app_dev}",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "kysely-codegen --out-file app/lib/db/database-types.ts",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{ts,tsx}\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@ai-sdk/react": "^3.0.192",
    "@mantine/core": "^9.2.1",
    "@mantine/form": "^9.2.1",
    "@mantine/hooks": "^9.2.1",
    "@mantine/modals": "^9.2.1",
    "@mantine/notifications": "^9.2.1",
    "@mantine/nprogress": "^9.2.1",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "ai": "^6.0.190",
    "better-auth": "^1.6.11",
    "isbot": "^5",
    "kysely": "^0.29.2",
    "lucide-react": "^1.16.0",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "7.15.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,mjs,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "7.15.1",
    "@tailwindcss/node": "^4.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/eslint-plugin": "^1.6.18",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "kysely-codegen": "^0.20.0",
    "lint-staged": "^17.0.5",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.6"
  }
}
