# Connection string used by Prisma and Kysely at runtime.
DATABASE_URL="postgresql://app:password@localhost:5432/app_dev"
# Playwright uses a separate test database by default so E2E tests do not
# mutate the development database. Override this only when your local test
# database uses a different URL.
# E2E_DATABASE_URL="postgresql://app:password@localhost:5432/app_test"

# PostgreSQL container credentials (used by docker-compose).
POSTGRES_USER=app
POSTGRES_PASSWORD=password
POSTGRES_DB=app_dev
POSTGRES_PORT=5432

# Port the production server listens on (react-router-serve).
APP_PORT=3000

# Secret for signing auth tokens. Must be at least 32 random characters.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Base URL of the running app. Use 5173 for `pnpm dev`; 3000 for production.
BETTER_AUTH_URL=http://localhost:5173
# Comma-separated origins allowed for CORS/auth callbacks.
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# Microsoft OAuth (optional; leave blank to disable Microsoft sign-in).
# Register an app at https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Set the redirect URI to: <BETTER_AUTH_URL>/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Tenant ID: use "common" for any Microsoft account, or a specific tenant GUID.
# MICROSOFT_TENANT_ID=common

# Optional: override seed demo account defaults (see prisma/seed.ts).
# SEED_USER_EMAIL=demo@example.com
# SEED_USER_NAME=Demo User
# SEED_USER_PASSWORD=DemoPassword123!

# AI chatbot (optional; leave all three blank to disable the /demo/dashboard chat sidebar).
# Any OpenAI-compatible endpoint works (OpenAI, Together, Groq, DeepSeek, Ollama via openai-compatible shim, etc.).
# Example:
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL_ID=provider-model-id
AI_BASE_URL=
AI_MODEL_ID=
AI_API_KEY=

# Admin access (optional). Space-separated list of emails that may open /admin.
# These users see the "Admin" link in the dashboard header and can ban/unban
# users and manage projects. Leave blank to disable the admin area entirely.
# Example: ADMIN_EMAILS="alice@example.com bob@example.com"
ADMIN_EMAILS=
